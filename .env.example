# Ghost Palette — environment template.
# Copy to `.env.local` and fill in real values, or let `clerk init` populate them.
# Never commit real keys. `.env.local` is gitignored; this file is the safe template.

# ── Clerk authentication ──────────────────────────────────────────────
# From https://dashboard.clerk.com → API keys (or written by `clerk init`).

# Publishable key — safe to expose to the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key — server-only. Keep out of client code and version control.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# We use our own themed auth pages (not Clerk's hosted UI), so point Clerk
# at the local routes and where to land after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/studio
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/studio

# ── fal.ai (image generation) ─────────────────────────────────────────
# Server-only API key. Get one at https://fal.ai/dashboard/keys
FAL_KEY=fal_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (database + image storage) ───────────────────────────────
# From your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# ── Stripe (credit subscriptions) ─────────────────────────────────────
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# Added after the webhook endpoint is created (stripe listen / dashboard).
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ── Logging ───────────────────────────────────────────────────────────
# Server log verbosity: debug | info | warn | error (default: info in prod, debug in dev).
LOG_LEVEL=debug

# Secret Vercel Cron sends as Authorization: Bearer for /api/cron/refresh
CRON_SECRET=

# Clerk webhook signing secret (Dashboard → Webhooks → your endpoint) for /api/clerk/webhook
CLERK_WEBHOOK_SIGNING_SECRET=
